{
  "name": "rawallmconfig",
  "version": "0.1.4",
  "description": "Local desktop app for inspecting and safely managing Claude, Codex, MCP, hooks, local models, and AI workspace configuration.",
  "author": "RaWaLLMConfig contributors",
  "packageManager": "pnpm@11.15.0",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/RaWa-KI/RaWaLLMConfig.git"
  },
  "bugs": {
    "url": "https://github.com/RaWa-KI/RaWaLLMConfig/issues"
  },
  "homepage": "https://github.com/RaWa-KI/RaWaLLMConfig",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm test:service",
    "test:service": "pnpm exec playwright test --config tests/write/playwright.config.ts",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "smoke:flows": "node scripts/ui-smoke-flows.mjs",
    "smoke:package:linux": "node scripts/linux-package-smoke.mjs",
    "perf:ui": "node scripts/perf-smoke.mjs",
    "verify": "pnpm typecheck && pnpm test:service && pnpm build && pnpm smoke:ui && pnpm perf:ui",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "dist": "pnpm dist:win",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:all": "electron-vite build && electron-builder --win --linux",
    "manifest:local": "node scripts/generate-update-manifest.mjs",
    "release:export": "node scripts/release/export-public-source.mjs",
    "release:verify": "node scripts/release/verify-public-source.mjs",
    "release:notices": "node scripts/release/generate-third-party-notices.mjs"
  },
  "dependencies": {
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/merge": "6.12.1",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0",
    "chokidar": "^5.0.0",
    "codemirror": "6.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "typescript": "^5.7.0",
    "vite": "8.0.16"
  }
}
